{
  "entities": {
    "Item": {
      "title": "Lost or Found Item",
      "description": "Represents a lost or found item posted by a student.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "location": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["lost", "found"] },
        "imageUrl": { "type": "string" },
        "reporterId": { "type": "string" },
        "reporterName": { "type": "string" },
        "reporterEmail": { "type": "string" },
        "reporterPhoto": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "resolved"] },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "description", "category", "location", "date", "type", "reporterId", "reporterName", "status", "createdAt"]
    },
    "User": {
      "title": "User Profile",
      "description": "Stores user XP and profile info.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "xp": { "type": "number" },
        "helpfulReturns": { "type": "number" }
      },
      "required": ["displayName", "xp"]
    }
  },
  "firestore": {
    "/items/{itemId}": {
      "schema": "Item",
      "description": "Public collection for all lost and found items."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Private profile data for users including XP."
    }
  }
}
