rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(reporterId) {
      return isSignedIn() && request.auth.uid == reporterId;
    }

    // Pillar 2: Validation Blueprint
    function isValidItem(data) {
      return data.keys().hasAll(['title', 'description', 'category', 'location', 'date', 'type', 'reporterId', 'reporterName', 'status', 'createdAt'])
        && data.keys().size() <= 13
        && data.title is string && data.title.size() >= 3 && data.title.size() <= 100
        && data.description is string && data.description.size() <= 1000
        && data.category is string && data.category.size() <= 50
        && data.location is string && data.location.size() <= 100
        && data.date is string && data.date.size() <= 50
        && data.type in ['lost', 'found']
        && data.reporterId == request.auth.uid
        && data.reporterName is string && data.reporterName.size() <= 100
        && data.status in ['active', 'resolved']
        && data.createdAt is number
        && (data.get('imageUrl', null) == null || (data.imageUrl is string && data.imageUrl.size() <= 500))
        && (data.get('reporterPhoto', null) == null || (data.reporterPhoto is string && data.reporterPhoto.size() <= 500))
        && (data.get('reporterEmail', null) == null || (data.reporterEmail is string && data.reporterEmail.size() <= 200));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'xp'])
        && data.keys().size() <= 6
        && data.displayName is string && data.displayName.size() <= 100
        && data.xp is number
        && (data.get('photoURL', null) == null || (data.photoURL is string && data.photoURL.size() <= 500))
        && (data.get('helpfulReturns', null) == null || data.helpfulReturns is number)
        && (data.get('email', null) == null || (data.email is string && data.email.size() <= 200));
    }

    // Phase 4: Match Blocks
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn() && resource.data.displayName != null;
      allow create, update: if isOwner(userId) && isValidUser(incoming());
    }

    match /items/{itemId} {
      // Pillar 3: Path Variable Hardening
      allow get: if isSignedIn() && isValidId(itemId);
      
      // Pillar 8: Secure List Queries
      allow list: if isSignedIn(); 

      allow create: if isSignedIn() 
        && isValidId(itemId)
        && isValidItem(incoming())
        && incoming().status == 'active';

      allow update: if isOwner(existing().reporterId)
        && isValidItem(incoming())
        && incoming().createdAt == existing().createdAt
        && (
          // Action: Mark as resolved
          (incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
          // Action: Edit details
          (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'category', 'location', 'date', 'imageUrl']))
        );

      allow delete: if isOwner(existing().reporterId);
    }
  }
}
